{
  "name": "js-ephemeris",
  "version": "0.0.1",
  "description": "High-precision solar system ephemeris engine. Zero dependencies, Browser & Node.js.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./moshier": {
      "types": "./dist/moshier/index.d.ts",
      "import": "./dist/moshier/index.js"
    },
    "./loader/node": {
      "types": "./dist/loader/node.d.ts",
      "import": "./dist/loader/node.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RedSC1/js-ephemeris.git"
  },
  "keywords": [
    "ephemeris",
    "astronomy",
    "planetary",
    "solar-system",
    "de441",
    "moshier",
    "chebyshev",
    "celestial-mechanics"
  ],
  "author": "RedSC1",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/RedSC1/js-ephemeris/issues"
  },
  "homepage": "https://github.com/RedSC1/js-ephemeris#readme",
  "devDependencies": {
    "@types/node": "^25.7.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
